  }
]

-- ── Scene step shape ────────────────────────────────────────────────
-- A scene is a list of `Step`s. Most steps are dialogue beats; some
-- branch via `choose`; some trigger a battle; some end the scene.
--
-- We don't model these as a tagged union (LeanJs records don't carry
-- variants yet) — instead each Step has every field, with sentinel
-- values telling the runner which kind it is:
--
--   speaker != ""  → dialogue beat
--   choices != []  → choice menu
--   battle != ""   → start a battle, scene resumes when it ends
--   gotoScene != "" → jump to another scene (id)
--   ending != ""   → ending screen
--
-- `apply` (the effects dict on a choice) is a record of integer deltas
-- that get added to `state.stats` and `state.flags`.

record Step where
  -- dialogue
  bg : String,             -- background palette id
  speakerJa : String, speakerEn : String,
  sayJa : String, sayEn : String,
  thinkJa : String, thinkEn : String,   -- inner monologue, "" = none
  spriteId : String, spriteName : String, spriteColor : String,
  spriteId2 : String, spriteName2 : String, spriteColor2 : String,
  spriteFocus : Int,       -- 0 = none, 1 = first, 2 = second
  -- choice menu
  choices : Array,
  -- transitions
  battle : String,         -- battle id to enter, "" = no battle
  gotoScene : String,      -- "" = continue same scene
  ending : String          -- "" = no ending; otherwise ending id

record Choice where
  labelJa : String, labelEn : String,
  hintJa : String, hintEn : String,
  dKarma : Int, dWife : Int, dWifeFear : Int,
  dTrust : Int, dMinXin : Int,
  dBu : Int, dZhi : Int, dMei : Int, dZheng : Int,
  setFlag : String,
  gotoScene : String      -- branch destination ("" = next step)

-- Convenience constructors --------------------------------------------
def blankChoice :=
  Choice {
    labelJa: "", labelEn: "",
    hintJa: "", hintEn: "",
    dKarma: 0, dWife: 0, dWifeFear: 0,
    dTrust: 0, dMinXin: 0,
    dBu: 0, dZhi: 0, dMei: 0, dZheng: 0,
    setFlag: "", gotoScene: ""
  }

def blankStep :=
  Step {
    bg: "bg-pei",
    speakerJa: "", speakerEn: "",
    sayJa: "", sayEn: "",
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: [],
    battle: "", gotoScene: "", ending: ""
  }

-- A dialogue beat ----------------------------------------------------
def say(bg, who, color, sayJa, sayEn) :=
  Step {
    bg: bg,
    speakerJa: who, speakerEn: who,
    sayJa: sayJa, sayEn: sayEn,
    thinkJa: "", thinkEn: "",
    spriteId: who, spriteName: who, spriteColor: color,
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 1,
    choices: [],
    battle: "", gotoScene: "", ending: ""
  }

-- A dialogue beat with inner monologue --------------------------------
def think(bg, who, color, sayJa, sayEn, thinkJa, thinkEn) :=
  Step {
    bg: bg,
    speakerJa: who, speakerEn: who,
    sayJa: sayJa, sayEn: sayEn,
    thinkJa: thinkJa, thinkEn: thinkEn,
    spriteId: who, spriteName: who, spriteColor: color,
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 1,
    choices: [],
    battle: "", gotoScene: "", ending: ""
  }

-- A two-sprite beat ---------------------------------------------------
def duo(bg, who, color, who2, color2, focus, sayJa, sayEn) :=
  Step {
    bg: bg,
    speakerJa: who, speakerEn: who,
    sayJa: sayJa, sayEn: sayEn,
    thinkJa: "", thinkEn: "",
    spriteId: who, spriteName: who, spriteColor: color,
    spriteId2: who2, spriteName2: who2, spriteColor2: color2,
    spriteFocus: focus,
    choices: [],
    battle: "", gotoScene: "", ending: ""
  }

-- A narration line (no speaker, no sprite) ---------------------------
def narr(bg, sayJa, sayEn) :=
  Step {
    bg: bg,
    speakerJa: "", speakerEn: "",
    sayJa: sayJa, sayEn: sayEn,
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: [],
    battle: "", gotoScene: "", ending: ""
  }

-- A choice menu -------------------------------------------------------
def chooseStep(bg, cs) :=
  Step {
    bg: bg,
    speakerJa: "", speakerEn: "",
    sayJa: "", sayEn: "",
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: cs,
    battle: "", gotoScene: "", ending: ""
  }

-- Transitions ---------------------------------------------------------
def goScene(id) :=
  Step {
    bg: "",
    speakerJa: "", speakerEn: "",
    sayJa: "", sayEn: "",
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: [],
    battle: "", gotoScene: id, ending: ""
  }

def doBattle(id) :=
  Step {
    bg: "",
    speakerJa: "", speakerEn: "",
    sayJa: "", sayEn: "",
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: [],
    battle: id, gotoScene: "", ending: ""
  }

def endingStep(id) :=
  Step {
    bg: "",
    speakerJa: "", speakerEn: "",
    sayJa: "", sayEn: "",
    thinkJa: "", thinkEn: "",
    spriteId: "", spriteName: "", spriteColor: "",
    spriteId2: "", spriteName2: "", spriteColor2: "",
    spriteFocus: 0,
    choices: [],
    battle: "", gotoScene: "", ending: id
  }

-- ── Story content ───────────────────────────────────────────────────
-- Liu Bang Act 1 — Pei, 蕭何 meeting, 呂公 banquet, marriage, 白蛇 episode.
-- ~30 beats. The two-layer dialogue (outer + inner) is the centerpiece.

def colorLiu := "#7a5a2a"
def colorXiao := "#5a3a6a"
def colorLu := "#a08060"
def colorLuFather := "#4a3a2a"
def colorFan := "#3a5a3a"

def liubangAct1 := [
  -- Opening narration
  narr("bg-pei",
    "紀元前 209 年、秦の暴政の末、各地に蜂起の火が燃え始めていた。沛の街、亭長・劉邦は今日も酒場で部下たちと笑っている――。",
    "BCE 209. As the Qin tyranny crumbles, rebellions kindle across the realm. In the town of Pei, the local headman Liu Bang is drinking with his men, as he does every day."),

  -- Liu Bang as he appears: charm + calculation
  think("bg-pei", "劉邦", colorLiu,
    "「おう樊噲、もう一杯くれや。今日もお前の犬肉は天下一だぜ!」",
    "“Hey Fan Kuai, pour me another. Your dog meat's the best under heaven!“",
    "こいつの店で飲む銭はいつも俺の懐じゃねえ。だが樊噲は俺に惚れこんでる――惚れさせてる、というべきか。",
    "I never actually pay for these drinks. But Fan Kuai's loyal — I made sure of that. Charm is a long-term investment."),

  say("bg-pei", "樊噲", "#6a4a2a",
    "「兄貴ぃ、また宴会のツケ溜まってるよ! 嫁さんに怒られちまうって!」",
    "“Bro, your tab is climbing again! My wife's gonna chew me out!“"),

  think("bg-pei", "劉邦", colorLiu,
    "「いいから飲め飲め! お前のおっかぁの分も俺が払うって!」",
    "“Drink up, drink up! I'll cover your mom's share too!“",
    "払う気は無い。だが「払う」と言える男は信頼される。世の中そういうもんだ。",
    "I'm not going to pay. But a man who says he will is trusted. That's how the world works."),

  -- Enter 蕭何
  narr("bg-pei",
    "そこへ、地味な役人風の男が顔をしかめて入ってくる。沛の主吏・蕭何である。",
    "A drab-looking official enters, frowning. Xiao He, chief clerk of Pei."),

  duo("bg-pei", "蕭何", colorXiao, "劉邦", colorLiu, 1,
    "「劉殿。また亭の業務をすっぽかして飲んでおられるのですな。今日は租税の帳簿の照合があったはずですが」",
    "“Master Liu. Skipping your post to drink again, are we? You had tax-ledger reconciliation today.“"),

  think("bg-pei", "劉邦", colorLiu,
    "「おお蕭何さんよぉ! また帳簿合わせてくれたんかい、悪いなぁ恩に着るぜ!」",
    "“Ah Xiao He! Did you balance those ledgers for me again? You're a saint, brother.“",
    "よく分からん字書きだが、こいつ抑えとけば沛の役人衆は逃げねえ。",
    "Boring clerk, but pin him down and the rest of Pei's bureaucracy stays put."),

  say("bf-pei", "蕭何", colorXiao,
    "「……いえ。当然のことです。あなたが帳簿を間違えると、結局尻拭いは私になりますから」",
    "“...It's nothing. If your numbers are wrong I'm the one cleaning up.“"),

  think("bg-pei", "劉邦", colorLiu,
    "「お前ぁ堅物だなぁ。今度俺ンとこ来て一杯やろうや、嫁にも会ってくれよ」",
    "“You're so stiff, my friend. Come over sometime, drink with me. Meet the wife.“",
    "嫁はまだ居ねえ。だがこの言葉、後で布石になる。",
    "I don't actually have a wife yet. But these words will be useful later."),

  -- Choice 1: a small one to introduce the system
  chooseStep("bg-pei", [
    Choice {
      labelJa: "蕭何の真面目さを、皆の前でからかう",
      labelEn: "Tease Xiao He's earnestness in front of the others",
      hintJa: "笑いは取れる。が、蕭何の心に小さな傷",
      hintEn: "A laugh from the crowd, but a small wound in Xiao He",
      dKarma: 1, dWife: 0, dWifeFear: 0,
      dTrust: -1, dMinXin: 0,
      dBu: 0, dZhi: 0, dMei: 1, dZheng: 0,
      setFlag: "tease_xiaohe", gotoScene: ""
    },
    Choice {
      labelJa: "酒を一杯、蕭何に差し出す",
      labelEn: "Quietly pour Xiao He a cup",
      hintJa: "誠実な振る舞い。だが「らしくない」と樊噲は訝しむ",
      hintEn: "Sincere — but Fan Kuai will find it out of character",
      dKarma: 0, dWife: 0, dWifeFear: 0,
      dTrust: 2, dMinXin: 0,
      dBu: 0, dZhi: 0, dMei: 0, dZheng: 1,
      setFlag: "drink_xiaohe", gotoScene: ""
    },
    Choice {
      labelJa: "蕭何の家族構成を、それとなく聞き出す",
      labelEn: "Casually probe Xiao He about his family",
      hintJa: "情報は力。だが、この場で気付く者がいるかも",
      hintEn: "Information is power. Someone may notice though",
      dKarma: 2, dWife: 0, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 2, dMei: 0, dZheng: 1,
      setFlag: "probe_xiaohe", gotoScene: ""
    }
  ]),

  -- Continue: 呂公 arrives in Pei
  narr("bg-pei",
    "数日後。隣県・単父より逃れてきた呂公という名士が、沛の県令の客分となり、屋敷で大宴を開いた。賀銭一千以上の者は上座、それ以下は下座という。",
    "Days later. A notable named Lord Lü, fled here from the next county, becomes a guest of the magistrate and throws a banquet. Those who bring more than a thousand in gift money sit upstairs; the rest below."),

  duo("bg-banquet", "蕭何", colorXiao, "劉邦", colorLiu, 1,
    "「劉殿、まさかとは思いますが――銭を持たずに行く気では?」",
    "“Master Liu. Surely you're not... thinking of going without money?“"),

  think("bg-banquet", "劉邦", colorLiu,
    "「銭? ねえに決まってんじゃねえか」",
    "“Money? Of course I don't have any.“",
    "だが、銭が無くても上座に座る方法を、俺は知っている。",
    "But I know how to sit upstairs without any."),

  -- Choice 2: THE choice — the famous "賀銭一万" lie
  chooseStep("bg-banquet", [
    Choice {
      labelJa: "正直に「銭は無い」と書いて下座へ座る",
      labelEn: "Write honestly: “no money,“ and take a seat downstairs",
      hintJa: "誠実。だが、この物語の劉邦はその道を選ばない――選んでしまえば、呂雉とは出会えない",
      hintEn: "Honest. But this Liu Bang doesn't take that path. Choose it and you never meet Lü Zhi",
      dKarma: -2, dWife: 0, dWifeFear: 0,
      dTrust: 1, dMinXin: 1,
      dBu: 0, dZhi: 0, dMei: 0, dZheng: 0,
      setFlag: "banquet_honest", gotoScene: "liubang_honest_dead_end"
    },
    Choice {
      labelJa: "受付の札に「賀銭一万」と堂々と書く",
      labelEn: "Write “Ten thousand in gift money“ on the receipt, bold-faced",
      hintJa: "嘘。だが上座へ通される。呂公はお前の人相を見るだろう",
      hintEn: "A lie. But it gets you upstairs. And Lord Lü will read your face",
      dKarma: 4, dWife: 0, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 1, dMei: 2, dZheng: 2,
      setFlag: "banquet_lie", gotoScene: ""
    }
  ]),

  -- Liar's path continues
  narr("bg-banquet",
    "受付の役人は「賀銭一万」の札に目を丸くする。慌てて呂公本人が出てきて、劉邦の顔を一目見るなり――席を立った。",
    "The receptionist gapes at the ten-thousand card. Lord Lü himself comes out — looks at Liu Bang's face — and rises from his seat."),

  say("bg-banquet", "呂公", colorLuFather,
    "「……君。上座へ。否、私の隣へ」",
    "“...You. Upstairs. No — beside me.“"),

  think("bg-banquet", "劉邦", colorLiu,
    "「いやぁ、こりゃ恐縮ですなぁ呂公!」",
    "“Hah, this is too much honor, Lord Lü!“",
    "顔相見の好きな爺さんと聞いていたが、本当に俺の顔を見て驚いている。利用できる。",
    "I'd heard he reads faces. He really is startled by mine. This I can use."),

  -- 蕭何 is uneasy
  duo("bg-banquet", "蕭何", colorXiao, "劉邦", colorLiu, 1,
    "「劉殿……」",
    "“Master Liu...“"),

  think("bg-banquet", "劉邦", colorLiu,
    "「な、なんだよ蕭何」",
    "“W-what is it, Xiao He?“",
    "こいつ、俺の嘘を見抜いてやがる。だが場で告発する勇気もねえ。安心して座らせとけ。",
    "He's seen through the lie. But he won't denounce me here. Safe."),

  say("bg-banquet", "蕭何", colorXiao,
    "「……いえ。ご自愛を」",
    "“...Nothing. Take care of yourself.“"),

  -- 呂公 offers his daughter
  narr("bg-banquet",
    "宴の終盤、呂公は劉邦を奥の間に呼び――驚くべきことを切り出した。",
    "As the banquet winds down, Lord Lü calls Liu Bang to a private room — and makes a remarkable offer."),

  say("bg-banquet", "呂公", colorLuFather,
    "「君に、私の娘を娶ってもらいたい。雉という。十九になる」",
    "“I want you to marry my daughter. Lü Zhi. She's nineteen.“"),

  think("bg-banquet", "劉邦", colorLiu,
    "「えっ、ええっ?! い、いやぁ俺なんかにそんな!」",
    "“Wh-what?! M-me? I couldn't possibly!“",
    "来た。だが慌てた顔をしないと「狙ってた」と勘付かれる。",
    "There it is. Look surprised — too eager and he'll realize this was planned."),

  -- Meeting 呂雉
  narr("bg-house",
    "翌日、呂家の客間。劉邦は初めて呂雉と対面した。",
    "Next morning, the guest hall of the Lü residence. Liu Bang meets Lü Zhi for the first time."),

  duo("bg-house", "呂雉", colorLu, "劉邦", colorLiu, 1,
    "「……あなたが劉季と。年は」",
    "“...So you are Liu Ji. How old.“"),

  think("bg-house", "劉邦", colorLiu,
    "「あ、ああ。三十……まあ、四十には届かねえくらいかな。お、お雉さん? でいいのかな?」",
    "“Ah, around thirty... well, not quite forty. Lady... Zhi?“",
    "実年齢は四十過ぎ。が、女に歳を悟られるのは損だ。",
    "I'm past forty. Letting a woman know that is bad business."),

  duo("bg-house", "呂雉", colorLu, "劉邦", colorLiu, 1,
    "「……父があなたを婿にと。私は、父の決めたことに従います。ただ一つだけ」",
    "“...Father has chosen you. I will obey his choice. With one thing.“"),

  -- A second look at 呂雉 — sets up her later transformation
  duo("bg-house", "呂雉", colorLu, "劉邦", colorLiu, 1,
    "「あなたが私を妻と呼ぶならば、生涯、私を捨てないこと。捨てるならば、私はあなたを地獄まで追いますよ」",
    "“If you call me your wife, you will never abandon me. If you do — I will chase you to hell.“"),

  think("bg-house", "劉邦", colorLiu,
    "「あ、ああ……約束する。捨てねえ。絶対だ」",
    "“Ah, ah... I promise. Never. Absolutely.“",
    "この女、十九にしてこの目をしている。これは敵にしたら厄介だな。味方にしておくか。",
    "Nineteen, and those eyes. Dangerous as an enemy. Better as an ally."),

  -- Choice 3: how to respond to her ultimatum
  chooseStep("bg-house", [
    Choice {
      labelJa: "「俺はお前を女として愛そう」と心にもないことを言う",
      labelEn: "Tell her “I will love you as a woman“ — meaning none of it",
      hintJa: "嘘で愛情を確保する。後で見透かされた時の業は重い",
      hintEn: "Buying her affection with a lie. The reckoning later is heavy",
      dKarma: 5, dWife: 8, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 0, dMei: 3, dZheng: 1,
      setFlag: "lu_lie_love", gotoScene: ""
    },
    Choice {
      labelJa: "「俺は約束は守る男だ」と事実だけ告げる",
      labelEn: "Just say “I keep my promises“ and leave it at that",
      hintJa: "誠実だが冷たい。呂雉はその冷たさに気付き、後年「夫は私を女と見たことが無い」と思う",
      hintEn: "Honest but cold. She will remember it — and in old age think “my husband never saw me as a woman“",
      dKarma: 0, dWife: 2, dWifeFear: 4,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 1, dMei: 0, dZheng: 2,
      setFlag: "lu_cold_promise", gotoScene: ""
    },
    Choice {
      labelJa: "「お前は強い女だな」と笑う",
      labelEn: "Just laugh: “You're a strong woman“",
      hintJa: "対等の評価。呂雉の中の何かが、ほどける",
      hintEn: "An equal's praise. Something in her unclenches",
      dKarma: -1, dWife: 5, dWifeFear: 2,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 1, dMei: 2, dZheng: 1,
      setFlag: "lu_strong_laugh", gotoScene: ""
    }
  ]),

  -- Time passes
  narr("bg-house",
    "三年が過ぎた。劉邦と呂雉の間には長男・劉盈(後の恵帝)と長女・魯元公主が生まれていた。劉邦は相変わらず亭長として日々を過ごしていた――そして、ある日。",
    "Three years pass. Liu Ying (later Emperor Hui) is born, and a daughter. Liu Bang still serves as headman — and then, one day."),

  -- 白蛇 incident → 芒碭山 flight
  say("bg-mountain", "劉邦", colorLiu,
    "「徭役の囚人を 驪山まで護送する? また面倒な役回りだぜ」",
    "“Escort labor convicts to Mount Li? Another mess of an assignment.“"),

  narr("bg-mountain",
    "ところが行軍の途中、囚人たちが次々と逃亡。秦律ではこれは護送官の死罪。劉邦は決断する――。",
    "But on the march, the convicts begin slipping away. By Qin law, this is a death sentence for the escort. Liu Bang makes a decision—"),

  chooseStep("bg-mountain", [
    Choice {
      labelJa: "残った囚人を全員解放し、自分も逃亡する",
      labelEn: "Free the remaining convicts and run with them",
      hintJa: "歴史通りの選択。沼沢の中で「白蛇を斬る」伝説の場へ",
      hintEn: "The historical choice. Onto the marshes — and the legend of the slain white serpent",
      dKarma: 0, dWife: 0, dWifeFear: 1,
      dTrust: 5, dMinXin: 5,
      dBu: 1, dZhi: 0, dMei: 3, dZheng: 0,
      setFlag: "freed_convicts", gotoScene: "liubang_white_serpent"
    },
    Choice {
      labelJa: "残った囚人を全員斬って沛に帰る",
      labelEn: "Cut down the remaining convicts and report back to Pei",
      hintJa: "保身。だが「あの劉季は冷たい男だ」という噂は沛中に広がる",
      hintEn: "Self-preservation. But “that Liu Ji is a cold man“ will spread through Pei",
      dKarma: 8, dWife: 0, dWifeFear: 0,
      dTrust: -3, dMinXin: -10,
      dBu: 2, dZhi: 0, dMei: -5, dZheng: 0,
      setFlag: "killed_convicts", gotoScene: "liubang_act1_end_bad"
    }
  ])
]

-- 白蛇 incident scene
def liubangWhiteSerpent := [
  narr("bg-mountain",
    "夜。劉邦と十数人の元囚人は沼沢を渡る。月の無い闇。先頭を行く一人が悲鳴を上げて戻ってくる――。",
    "Night. Liu Bang and a dozen freed convicts wade through marshland. The moon is dark. The scout runs back, screaming."),

  say("bg-mountain", "元囚人", "#6a4a2a",
    "「兄貴! 道に大蛇が! 白い大蛇です!」",
    "“Bro! A giant snake on the path! A white serpent!“"),

  think("bg-mountain", "劉邦", colorLiu,
    "「蛇? ふん、酔っぱらいの英雄が蛇を恐れるわけがねえだろ。退きやがれ!」",
    "“A snake? Hah, would the drunk hero fear a snake? Stand aside!“",
    "もう酒は抜けかかってる。怖い。だが、ここで怯えたら一生「あいつは蛇に逃げた男」だ。",
    "The drink's wearing off. I'm scared. But if I flinch here, I'm 'the man who ran from a snake' for life."),

  narr("bg-mountain",
    "劉邦は剣を抜き、闇の中へ進む。一閃。白蛇は両断された。劉邦はそのまま酔いに任せて倒れこむ。翌朝、後を追ってきた者が言う――。",
    "Liu Bang draws his sword and walks into the dark. A single stroke. The white serpent is cleaved in two. He collapses, drunk. Next morning, those who came after him say—"),

  say("bg-mountain", "老婆", "#aaa",
    "「私の子が斬られた! 私の子は白帝の子。斬ったのは赤帝の子だ! ああ哀しや――」",
    "“My son has been slain! My son was the child of the White Emperor. He who slew him is the child of the Red Emperor! Oh sorrow—“"),

  narr("bg-mountain",
    "老婆はそう言うと、消えた。これより劉邦は「赤帝の子」と呼ばれ、芒碭山の沼沢に隠れ住み、徒党を集めはじめる。沛の役人衆も密かに食料を届けるようになった。蕭何、曹参、樊噲――彼らはすでに、この男を「主」と思い始めていた。",
    "She vanished. From then on Liu Bang was called “the child of the Red Emperor.“ He hid in the marshes of Mount Mang and Mount Dang, gathering a band. The clerks of Pei smuggled him food. Xiao He, Cao Shen, Fan Kuai — they were already beginning to think of this man as their lord."),

  -- Act 1 wrap
  narr("bg-mountain",
    "――こうして、無頼の亭長・劉邦は「沛公」となる。同じ頃、江東で叔父・項梁とともに兵を挙げた青年がいた。名を、項羽。そして淮陰では、まだ胯下の辱を受けていない貧しい青年がいた。名を、韓信。物語は、これから始まる。",
    "—And so the hooligan headman became “the Duke of Pei.“ At the same time, in Jiangdong, a young man took up arms with his uncle Xiang Liang. His name was Xiang Yu. And in Huai-yin, a poor young man — not yet the recipient of the bully's humiliation — was named Han Xin. The story begins now."),

  endingStep("act1_clear")
]

-- Dead-end branch (honest at the banquet)
def liubangHonestDeadEnd := [
  narr("bg-banquet",
    "劉邦は正直に「銭は無い」と書き、下座についた。呂公は彼の顔を見ることもなかった。呂雉と出会うことなく、劉邦は沛の無名の亭長として一生を終える――そんな静かな生にも、しかし、価値はあったかもしれない。",
    "Liu Bang wrote “no money“ honestly and sat downstairs. Lord Lü never saw his face. Liu Bang never met Lü Zhi and finished his days as a nameless headman in Pei. There is, perhaps, value in such a quiet life."),

  endingStep("honest_anonymous")
]

-- Bad branch (killed the convicts)
def liubangAct1EndBad := [
  narr("bg-mountain",
    "斬られた囚人の遺族は、劉邦の冷酷を沛中に喧伝した。樊噲は黙ったまま、酒場で劉邦に酒を出さなくなった。蕭何は二度と「劉殿」と呼ばなくなった。呂雉は何も言わなかったが、夜、子を抱きながら泣いていた。秦が倒れる頃、劉邦は誰一人従える者を持っていなかった――。",
    "The convicts' families spread word of Liu Bang's cruelty throughout Pei. Fan Kuai went silent, refused to serve him drink. Xiao He never called him “Master Liu“ again. Lü Zhi said nothing, but wept at night holding the child. When Qin fell, Liu Bang had not a single follower."),

  endingStep("cold_alone")
]

-- ── Stub Act 1s for the other five — playable but short ─────────────
def colorXiang := "#7a1a1a"
def colorYu := "#a05a5a"
def colorXiangLiang := "#6a1a1a"
def colorXiangBo := "#4a2a2a"

def xiangyuAct1 := [
  narr("bg-camp",
    "紀元前 209 年、会稽郡。項氏は楚の名将・項燕の末裔として、復楚の旗を秘かに磨いていた。", "BCE 209, Kuaiji. The Xiang clan, descendants of the great Chu general Xiang Yan, secretly polish the banner of Chu restoration."),
  think("bg-camp", "項羽", colorXiang,
    "「叔父上、こんな勉学などしておれぬ。俺は万人を相手に剣を振るう男になる。書なぞ、人の名を覚える程度で十分だ」",
    "“Uncle, I cannot bear this study. I will be a man who fights ten thousand. Letters? Enough to know a name by.“",
    "実は、書は嫌いだが、もっと嫌いなのは「他人より劣る」と感じる時だ。だから始める前に投げ出す。",
    "Truth is, I don't hate letters so much as the feeling of being lesser. So I quit before I start."),
  say("bg-camp", "項梁", colorXiangLiang,
    "「籍よ、お前は剣も書も学ばぬ。何を学ぶつもりだ」",
    "“Ji, my boy. Neither sword nor letters. What will you study then?“"),
  say("bg-camp", "項羽", colorXiang,
    "「学ぶなら、万人を敵にする術を学びます。一人を倒す術など、いりませぬ」",
    "“If I study, I will study the art of facing ten thousand. The art of slaying one — I do not need.“"),
  narr("bg-camp",
    "項梁はこの甥の眼を見て、苦笑した。項羽、二十二歳の夏である。", "Xiang Liang looks into his nephew's eyes and laughs ruefully. Xiang Yu is twenty-two that summer."),
  -- Choice: 会稽郡守を斬って蜂起するか
  chooseStep("bg-camp", [
    Choice {
      labelJa: "叔父の合図で会稽郡守・殷通を斬り、蜂起する",
      labelEn: "On uncle's signal, cut down Governor Yin Tong and raise the rebellion",
      hintJa: "歴史通り。項羽は数十人を一瞬で斬り、楚の旗が立つ",
      hintEn: "As history records. Xiang Yu cuts down dozens in moments, the Chu banner rises",
      dKarma: 2, dWife: 0, dWifeFear: 0,
      dTrust: 5, dMinXin: 3,
      dBu: 5, dZhi: 0, dMei: 2, dZheng: -1,
      setFlag: "killed_governor", gotoScene: "xiangyu_meet_yu"
    },
    Choice {
      labelJa: "「いま蜂起しても勝てぬ」と叔父に進言する",
      labelEn: "Counsel uncle that “now is not the time“",
      hintJa: "あり得ない選択。項羽はそういう男ではない。歴史改変ルートへ",
      hintEn: "Unthinkable. Xiang Yu is not such a man. Diverges into an alternate timeline",
      dKarma: -3, dWife: 0, dWifeFear: 0,
      dTrust: -2, dMinXin: 0,
      dBu: 0, dZhi: 3, dMei: 0, dZheng: 3,
      setFlag: "delayed_rebellion", gotoScene: "xiangyu_act1_stub_end"
    }
  ])
]

def xiangyuMeetYu := [
  narr("bg-camp",
    "蜂起の混乱の中、項羽は陣中で一人の女と出会う。江東の芸子、名を虞という。", "In the chaos of the rebellion, Xiang Yu meets a woman in camp. A performer from Jiangdong, called Yu."),
  duo("bg-camp", "虞姫", colorYu, "項羽", colorXiang, 1,
    "「あなたが項籍? 大したことない顔ね。聞いていたよりずっと普通」",
    "“You're Xiang Ji? Not much to look at. Far more ordinary than rumor.“"),
  think("bg-camp", "項羽", colorXiang,
    "「な――無礼な女だな貴様!」",
    "“You—! Insolent woman!“",
    "笑っている。なぜか、こいつに「普通」と言われると、嬉しい。",
    "She's laughing. For some reason, being called “ordinary“ by her — feels good."),
  narr("bg-camp", "二人の縁は、こうして始まった。垓下で終わるまで、八年の縁である。", "Their bond began thus. It would end at Gaixia, eight years later."),
  endingStep("xiangyu_act1_clear")
]

def xiangyuAct1StubEnd := [
