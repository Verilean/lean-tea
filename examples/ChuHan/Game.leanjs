  narr("bg-camp", "紀元前 209 年。范増、七十歳。世捨て人として暮らしていた老人は、突如、項梁の陣営を訪れた。", "BCE 209. Fan Zeng, seventy years old. A hermit, he suddenly arrives at Xiang Liang's camp."),
  duo("bg-camp", "范増", colorFanZeng, "項梁", colorXiangLiang, 1,
    "「項殿。陳勝の蜂起が失敗した理由をご存じか。彼は楚王の子孫を立てなかった。民心は、王の血を求めておる」",
    "“Lord Xiang. You know why Chen Sheng's rebellion failed? He did not raise up a scion of Chu. The people's hearts long for royal blood.“"),
  think("bg-camp", "范増", colorFanZeng,
    "「項殿は私の言を聞いてくださる。だが、その甥――項羽。あれは聞かぬ。あの眼を見ればわかる」",
    "“Lord Xiang will listen. But that nephew — Xiang Yu. He will not. I see it in his eyes.“",
    "亡き妻よ、お主が生きておったなら、何と言うであろうかな。「老いて尚、命を賭けるか」と笑うかもしれぬ。", "My late wife — what would you have said? Perhaps you'd have laughed: 'Still wagering your life, in your old age?'"),
  say("bg-camp", "項梁", colorXiangLiang,
    "「范増殿、ありがたきお言葉。楚の懐王の孫を探し出し、王に立てましょう」",
    "“Lord Fan Zeng, your wisdom honors us. We will find King Huai's grandson and raise him as king.“"),
  -- 范増 sees Liu Bang too
  narr("bg-camp", "後日、范増は楚の陣営に投じてきた劉邦の一団を観察する。", "Days later, Fan Zeng observes Liu Bang's band as they join the Chu camp."),
  think("bg-camp", "范増", colorFanZeng,
    "「あの男――劉季と申すか。雲気が龍の如し。あれは天下を取る相だ」",
    "“That man — Liu Ji? The cloud-aura above him is dragon-shaped. He has the face of one who will take all under heaven.“",
    "今、斬らねば後年に災いとなる。しかし――項梁殿はお優しすぎる。", "Kill him now or pay later. But — Lord Xiang Liang is too kind."),
  chooseStep("bg-camp", [
    Choice {
      labelJa: "項梁に「劉邦を斬れ」と進言する",
      labelEn: "Urge Xiang Liang: “Kill Liu Bang now“",
      hintJa: "正論。だが項梁は容れぬ。范増の進言が初めて『無視される』時",
      hintEn: "The right counsel. But Xiang Liang will not listen. The first time Fan Zeng's words are dismissed",
      dKarma: 0, dWife: 0, dWifeFear: 0,
      dTrust: 1, dMinXin: 0,
      dBu: 0, dZhi: 3, dMei: 0, dZheng: 2,
      setFlag: "warned_about_liu", gotoScene: "fanzeng_act1_end"
    },
    Choice {
      labelJa: "黙して時を待つ",
      labelEn: "Stay silent and bide time",
      hintJa: "後年の鴻門の宴で項羽に向かって叫ぶ伏線となる",
      hintEn: "Sets up the famous Hongmen banquet where you will scream at Xiang Yu",
      dKarma: -1, dWife: 0, dWifeFear: 0,
      dTrust: 0, dMinXin: 0,
      dBu: 0, dZhi: 2, dMei: 0, dZheng: 3,
      setFlag: "silent_about_liu", gotoScene: "fanzeng_act1_end"
    }
  ])
]

def fanzengAct1End := [
  narr("bg-camp", "范増の進言は、聞かれることもあり、聞かれぬこともあった。彼はやがて項羽の唯一の参謀となり――そして、最後に項羽に「お主はもう私の言を聞かぬか」と告げて、陣を去る。陣から故郷へ帰る途上、背に疽を発して死ぬ。八十歳前後である。", "Fan Zeng's counsel was sometimes heard, often not. He would become Xiang Yu's sole strategist — and one day tell Xiang Yu: “You no longer listen to me, do you?“ — and depart the camp. He dies on the road home of a back boil. Eighty, more or less."),
  endingStep("fanzeng_act1_clear")
]

-- ── Scene lookup ────────────────────────────────────────────────────
def sceneOf(id) :=
  match id with
  | "liubang_act1" => liubangAct1
  | "liubang_white_serpent" => liubangWhiteSerpent
  | "liubang_honest_dead_end" => liubangHonestDeadEnd
  | "liubang_act1_end_bad" => liubangAct1EndBad
  | "xiangyu_act1" => xiangyuAct1
  | "xiangyu_meet_yu" => xiangyuMeetYu
  | "xiangyu_act1_stub_end" => xiangyuAct1StubEnd
  | "hanxin_act1" => hanxinAct1
  | "hanxin_piao_mu" => hanxinPiaoMu
  | "hanxin_dead_end" => hanxinDeadEnd
  | "zhangliang_act1" => zhanglangAct1
  | "zhangliang_act1_end" => zhanglangAct1End
  | "zhangliang_no_bingfa_end" => zhanglangNoBingfaEnd
  | "xiaohe_act1" => xiaoheAct1
  | "xiaohe_act1_end" => xiaoheAct1End
  | "fanzeng_act1" => fanzengAct1
  | "fanzeng_act1_end" => fanzengAct1End
  | _ => []

def startSceneFor(charId) :=
  match charId with
  | "liubang" => "liubang_act1"
  | "xiangyu" => "xiangyu_act1"
  | "hanxin" => "hanxin_act1"
  | "zhangliang" => "zhangliang_act1"
  | "xiaohe" => "xiaohe_act1"
  | "fanzeng" => "fanzeng_act1"
  | _ => "liubang_act1"

-- ── State ───────────────────────────────────────────────────────────
record Stats where
  hp : Int, maxHp : Int,
  bu : Int, zhi : Int, mei : Int, zheng : Int,
  karma : Int,
  wife : Int, wifeFear : Int,
  trust : Int, minXin : Int,
  year : Int

def initStats := Stats {
  hp: 100, maxHp: 100,
  bu: 5, zhi: 5, mei: 5, zheng: 5,
  karma: 0, wife: 0, wifeFear: 0,
  trust: 0, minXin: 0,
  year: -209
}

record Battle where
  entities : Array, fx : Array,
  log : String

record Entity where
  kind : String,         -- "player" | "enemy"
  x : Int, y : Int,
  hp : Int, maxHp : Int,
  color : String,
  facingDx : Int, facingDy : Int,
  cooldown : Int,
  speed : Int

record Fx where
  x : Int, y : Int, r : Int, ttl : Int

def initBattle := Battle {
  entities: [],
  fx: [],
  log: ""
}

-- State
def initState := {
  phase: "title",
  lang: "ja",
  char: "",
  sceneId: "",
  beat: 0,
  stats: initStats,
  flags: {},
  battle: initBattle,
  endingId: "",
  toast: ""
}

-- ── Helpers for state manipulation ──────────────────────────────────
def applyChoiceToStats(s, c) := Stats {
  hp: s.hp, maxHp: s.maxHp,
  bu: s.bu + c.dBu, zhi: s.zhi + c.dZhi,
  mei: s.mei + c.dMei, zheng: s.zheng + c.dZheng,
  karma: s.karma + c.dKarma,
  wife: s.wife + c.dWife, wifeFear: s.wifeFear + c.dWifeFear,
  trust: s.trust + c.dTrust, minXin: s.minXin + c.dMinXin,
  year: s.year
}

-- Step lookup
def stepAt(scene, n) :=
  if n < arrLen(scene) then arrGet(scene, n) else blankStep

-- ── Update ──────────────────────────────────────────────────────────
def update(msg, state) :=
  match msg.tag with
  | "startSelect" => { phase: "select", lang: state.lang,
                       char: "", sceneId: "", beat: 0,
                       stats: state.stats, flags: state.flags,
                       battle: state.battle, endingId: "", toast: "" }
  | "pickChar" => (
    let cid := msg.id;
    let sid := startSceneFor(cid);
    { phase: "scene", lang: state.lang,
      char: cid, sceneId: sid, beat: 0,
      stats: initStats, flags: {},
      battle: initBattle, endingId: "", toast: "" })
  | "setLang" =>
    { phase: state.phase, lang: msg.lang,
      char: state.char, sceneId: state.sceneId, beat: state.beat,
      stats: state.stats, flags: state.flags,
      battle: state.battle, endingId: state.endingId, toast: state.toast }
  | "advance" => (
    if state.phase != "scene" then state
    else
      let scene := sceneOf(state.sceneId);
      let cur := stepAt(scene, state.beat);
      if cur.ending != "" then state
      else if arrLen(cur.choices) > 0 then state
      else if cur.gotoScene != "" then
        { phase: "scene", lang: state.lang,
          char: state.char, sceneId: cur.gotoScene, beat: 0,
          stats: state.stats, flags: state.flags,
          battle: state.battle, endingId: "", toast: state.toast }
      else
        let nb := state.beat + 1;
        let nxt := stepAt(scene, nb);
        if nxt.ending != "" then
          { phase: "ending", lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: nxt.ending, toast: state.toast }
        else if nxt.gotoScene != "" then
          { phase: "scene", lang: state.lang,
            char: state.char, sceneId: nxt.gotoScene, beat: 0,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: "", toast: state.toast }
        else
          { phase: state.phase, lang: state.lang,
            char: state.char, sceneId: state.sceneId, beat: nb,
            stats: state.stats, flags: state.flags,
            battle: state.battle, endingId: state.endingId, toast: state.toast })
  | "choose" => (
    let scene := sceneOf(state.sceneId);
    let cur := stepAt(scene, state.beat);
    let cs := cur.choices;
    let idx := msg.idx;
    if idx < arrLen(cs) then
      let c := arrGet(cs, idx);
      let newStats := applyChoiceToStats(state.stats, c);
      if c.gotoScene != "" then
        { phase: "scene", lang: state.lang,
          char: state.char, sceneId: c.gotoScene, beat: 0,
          stats: newStats, flags: state.flags,
          battle: state.battle, endingId: "", toast: c.setFlag }
      else
        { phase: state.phase, lang: state.lang,
          char: state.char, sceneId: state.sceneId, beat: state.beat + 1,
          stats: newStats, flags: state.flags,
          battle: state.battle, endingId: state.endingId, toast: c.setFlag }
    else state)
  | "reset" => initState
  | "backToSelect" => { phase: "select", lang: state.lang,
                        char: "", sceneId: "", beat: 0,
                        stats: initStats, flags: {},
                        battle: initBattle, endingId: "", toast: "" }
  | _ => state

-- ── View ────────────────────────────────────────────────────────────
-- HUD rendered on every phase except title.

def renderLang(state) :=
  let ja := if state.lang == "ja" then "active" else "";
  let en := if state.lang == "en" then "active" else "";
  sjoin([
    "<div class='lang'><button class='", ja,
    "' data-msg='{“tag“:“setLang“,“lang“:“ja“}'>JA</button><button class='", en,
    "' data-msg='{“tag“:“setLang“,“lang“:“en“}'>EN</button></div>"
  ])

def renderHud(state) :=
  let s := state.stats;
  let charName := match state.char with
    | "liubang"    => "劉邦"
    | "xiangyu"    => "項羽"
    | "hanxin"     => "韓信"
    | "zhangliang" => "張良"
    | "xiaohe"     => "蕭何"
    | "fanzeng"    => "范増"
    | _ => "";
  sjoin([
    "<div class='hud'><span class='who'>", hesc(charName),
    "</span><span class='stat'>武<b>", jstr(s.bu),
    "</b></span><span class='stat'>智<b>", jstr(s.zhi),
    "</b></span><span class='stat'>魅<b>", jstr(s.mei),
    "</b></span><span class='stat'>政<b>", jstr(s.zheng),
    "</b></span><span class='stat'>嫁<b>", jstr(s.wife),
    "</b></span><span class='yr'>BCE ", jstr(0 - s.year),
    "</span>", renderLang(state),
    "<button class='menu-btn' data-msg='{“tag“:“backToSelect“}'>選択へ</button></div>"
  ])

-- Title screen
def viewTitle(state) :=
  sjoin([
    "<div class='title-bg'><h1>楚漢恋歌</h1><div class='sub'>CHU·HAN LOVE SONG</div>",
    "<button class='btn' data-msg='{“tag“:“startSelect“}'>START</button>",
    "<div class='sub' style='font-size:11px;color:#666;margin-top:60px'>",
    "六つの生、六つの死、六つの恋。<br>BCE 209 ─ 195. Six lives. Six loves. Six deaths.</div></div>"
  ])

-- Character select grid
def renderCharCard(state, c) :=
  let selected := if state.char == c.id then "selected" else "";
  let nm := if state.lang == "en" then c.nameEn else c.nameJa;
  let ep := if state.lang == "en" then c.epithetEn else c.epithetJa;
  let desc := if state.lang == "en" then c.descEn else c.descJa;
  sjoin([
    "<div class='char-card ", selected,
    "' data-msg='{“tag“:“pickChar“,“id“:“", c.id,
    "“}'><div class='char-portrait' style='background:", c.color,
    "'>", hesc(nm),
    "</div><h3>", hesc(nm),
    "</h3><div class='epithet'>", hesc(ep),
    "</div><div class='desc'>", hesc(desc),
    "</div><div class='difficulty'>難易度: ", hesc(c.difficulty),
    "</div></div>"
  ])

def charLoop(state, cs, i, acc) :=
  if i < arrLen(cs) then
    charLoop(state, cs, i + 1,
      sconcat(acc, renderCharCard(state, arrGet(cs, i))))
  else acc

def viewSelect(state) :=
  let title := if state.lang == "en" then "Choose your fate" else "主人公を選べ";
  sjoin([
    "<div class='select-bg'>", renderHud(state),
    "<h2>", hesc(title), "</h2><div class='roster'>",
    charLoop(state, chars, 0, ""),
    "</div></div>"
  ])

-- Scene (dialogue) render
def renderSprite(name, color, dim) :=
  let dimC := if dim then " dim" else "";
  sjoin([
    "<div class='sprite", dimC,
    "' style='background:linear-gradient(180deg,", color,
    " 0%, ", color, " 60%, rgba(0,0,0,0.85) 100%)'>",
    hesc(name),
    "</div>"
  ])

def renderSprites(step) := (
  let s1id := step.spriteId;
  let s2id := step.spriteId2;
  let focus := step.spriteFocus;
  if s1id == "" then ""
  else if s2id == "" then
    sjoin(["<div class='sprite-row'>", renderSprite(step.spriteName, step.spriteColor, false), "</div>"])
  else
    let dim1 := focus == 2;
    let dim2 := focus == 1;
    sjoin([
      "<div class='sprite-row'>",
      renderSprite(step.spriteName, step.spriteColor, dim1),
      renderSprite(step.spriteName2, step.spriteColor2, dim2),
      "</div>"
    ]))

def renderDialogueBox(state, step) :=
  let say := if state.lang == "en" then (if step.sayEn == "" then step.sayJa else step.sayEn) else step.sayJa;
  let think := if state.lang == "en" then (if step.thinkEn == "" then step.thinkJa else step.thinkEn) else step.thinkJa;
  let speaker := if state.lang == "en" then (if step.speakerEn == "" then step.speakerJa else step.speakerEn) else step.speakerJa;
  let speakerHtml := if speaker == "" then ""
                     else sjoin(["<div class='dialogue-speaker'>", hesc(speaker), "</div>"]);
  let thinkHtml := if think == "" then ""
                   else sjoin(["<div class='dialogue-inner'>", hesc(think), "</div>"]);
  sjoin([
    "<div class='dialogue-box'>", speakerHtml,
    "<div class='dialogue-line'>", hesc(say), "</div>",
    thinkHtml,
    "<div class='advance-hint'>▼ space / click</div></div>"
  ])

def renderChoice(state, c, i) :=
  let label := if state.lang == "en" then (if c.labelEn == "" then c.labelJa else c.labelEn) else c.labelJa;
  let hint := if state.lang == "en" then (if c.hintEn == "" then c.hintJa else c.hintEn) else c.hintJa;
  let hintHtml := if hint == "" then ""
                  else sjoin(["<div class='hint'>", hesc(hint), "</div>"]);
  sjoin([
    "<button class='choice' data-msg='{“tag“:“choose“,“idx“:", jstr(i),
    "}'>", hesc(label), hintHtml, "</button>"
  ])

def choicesLoop(state, cs, i, acc) :=
  if i < arrLen(cs) then
    choicesLoop(state, cs, i + 1, sconcat(acc, renderChoice(state, arrGet(cs, i), i)))
  else acc

def renderChoices(state, step) :=
  let cs := step.choices;
  if arrLen(cs) == 0 then ""
  else sjoin(["<div class='choices'>", choicesLoop(state, cs, 0, ""), "</div>"])

def viewScene(state) :=
  let scene := sceneOf(state.sceneId);
  let step := stepAt(scene, state.beat);
  let bg := if step.bg == "" then "bg-pei" else step.bg;
  let advanceClick := if arrLen(step.choices) == 0
                      then " data-msg='{“tag“:“advance“}'" else "";
  sjoin([
    "<div class='scene-bg ", bg, "'", advanceClick, ">",
    renderHud(state),
    renderSprites(step),
    renderChoices(state, step),
    renderDialogueBox(state, step),
    "</div>"
  ])

-- Ending screen
def endingTitle(id) :=
  match id with
  | "act1_clear"        => "第一幕 完 ― 劉邦"
  | "honest_anonymous"  => "END: 無名の生"
  | "cold_alone"        => "END: 孤独の冷血漢"
  | "xiangyu_act1_clear" => "第一幕 完 ― 項羽"
  | "phase2_placeholder" => "(Phase 2 で続く)"
  | "hanxin_act1_clear" => "第一幕 完 ― 韓信"
  | "hanxin_pride_dead" => "END: 誇りに殉ず"
  | "zhangliang_act1_clear" => "第一幕 完 ― 張良"
  | "zhangliang_obscure" => "END: 無名の遺民"
  | "xiaohe_act1_clear" => "第一幕 完 ― 蕭何"
  | "fanzeng_act1_clear" => "第一幕 完 ― 范増"
  | _ => "END"

def viewEnding(state) :=
  sjoin([
    "<div class='title-bg'>",
    renderHud(state),
    "<h1 style='font-size:36px;letter-spacing:6px;color:#c8a96a'>",
    hesc(endingTitle(state.endingId)),
    "</h1>",
    "<div class='sub' style='color:#aaa;max-width:600px;text-align:center;line-height:1.8;font-size:14px'>",
    "MVP 第一幕の終わり。続きは Phase 2 で。<br>このまま遊び続けることもできます――他のルートを試してみてください。",
    "<br><br>End of Act I (MVP). Continue in Phase 2.<br>Try the other routes.",
    "</div>",
    "<button class='btn' data-msg='{“tag“:“backToSelect“}'>主人公選択へ戻る</button></div>"
  ])

-- Battle stub (no live entities yet — Phase 2 will populate)
def viewBattle(state) :=
  sjoin([
    "<div class='battle-bg'>",
    renderHud(state),
    "<canvas id='battleCanvas' width='640' height='400'></canvas>",
    "<div class='battle-hud'><span class='help'>WASD = move, Z = attack, ESC = retreat</span></div>",
    "<div class='battle-result'><div>(battle scaffolding ready — Phase 2)</div>",
    "<button data-msg='{“tag“:“backToSelect“}'>戻る</button></div></div>"
  ])

-- Top-level view
def view(state) :=
  match state.phase with
  | "title"   => viewTitle(state)
  | "select"  => viewSelect(state)
  | "scene"   => viewScene(state)
  | "battle"  => viewBattle(state)
  | "ending"  => viewEnding(state)
  | _ => viewTitle(state)

-- Smoke entry point so the LeanJs runner can verify the program
-- compiles and the initial render works without DOM.
def main := arrLen(chars)
