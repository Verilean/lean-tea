    color: "#5a3a6a",
    descJa: "沛の主吏。劉邦の友、漢の丞相、韓信の発見者にして処刑の手配人。「成也蕭何、敗也蕭何」。",
    descEn: "Pei's chief clerk. Liu Bang's friend, Han's chancellor. The man who discovered Han Xin and arranged his death.",
    difficulty: "内政専門", enabled: true
  },
  Char {
    id: "fanzeng",
    nameJa: "范増",     nameEn: "Fan Zeng",
