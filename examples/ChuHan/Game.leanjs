]

def zhanglangAct1End := [
  say("bg-river", "黄石公", colorHuangshi,
    "「孺子可教也」",
    "“The boy can be taught.“"),
  narr("bg-river", "張良は『太公兵法』を授かった。十年後、彼は劉邦と出会い、漢の軍師となる。引退して山に消える日まで、彼の戦は無敗である。", "Zhang Liang received the Tai Gong's Art of War. Ten years later he meets Liu Bang and becomes Han's strategist. Until the day he withdraws to the mountains, he never loses a campaign."),
  endingStep("zhangliang_act1_clear")
]

def zhanglangNoBingfaEnd := [
  narr("bg-river", "張良は黄石公の試練を蹴った。その後、彼は韓の遺民として平凡な生を送り、史に名を残さなかった。", "Zhang Liang refused. He lived out his days as an unremarkable Han remnant and never entered history."),
  endingStep("zhangliang_obscure")
]

-- 蕭何 Act 1 stub: 沛の主吏として劉邦を見る
def colorMiao := "#7a5a8a"

def xiaoheAct1 := [
  narr("bg-pei", "紀元前 209 年、沛。主吏・蕭何の朝は、劉邦の尻拭いから始まる。", "BCE 209, Pei. Chief clerk Xiao He's morning begins, as always, with cleaning up after Liu Bang."),
  think("bg-pei", "蕭何", colorXiao,
    "「また劉殿の帳簿が合わぬ。十文ほどの誤差。叱ろうか――いや、放っておこう」",
    "“Master Liu's ledger doesn't reconcile. About ten coins off. Should I scold him — no, let it pass.“",
    "なぜか、あの男の前では『正しさ』が貧相に見える。何だろう、この感覚は。", "For some reason, in front of that man, 'rightness' looks shabby. What is this feeling?"),
  duo("bg-house", "妙容", colorMiao, "蕭何", colorXiao, 1,
    "「あなた。また劉様のお勤めを肩代わりされたのですか? いつかご自分が損をなさいますよ」",
    "“Husband. Did you cover for Master Liu again? You will hurt yourself one day.“"),
  think("bg-house", "蕭何", colorXiao,
