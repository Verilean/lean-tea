# Lake build artifacts
.lake/

# Runtime state (SQLite DB, dist outputs, generated static)
.leantea-state/
dist/
*.sqlite
*.sqlite-journal

# GitHub Pages site is regenerated by `lake exe gen_site` and the
# `.github/workflows/pages.yml` workflow; never commit the output.
docs-site/

# Private examples (third-party IP / NSFW). Reintroduce locally by
# restoring `examples/_private/` and the corresponding lakefile.lean
# targets from a sibling private repo.
examples/_private/

# Python sidecar venvs + bytecode caches + Node deps
tools/**/.venv/
tools/**/__pycache__/
tools/**/node_modules/
**/node_modules/

# Personal LLM export dumps — regenerate via the `/ask-gemini` skill
gemini_*.md
gemini_*.txt
hesper_*.md
sparkle*.md

# Working notes (committed selectively — see docs/_drafts/demo-script.md
# for an example of a draft we *do* check in).
# Add file-level rules here as needed.

# macOS noise
.DS_Store
